---
import type { Product } from '../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const priceFormatted = (product.price / 100).toFixed(2);
const productUrl = `/shop/product/${product.slug}/`;
---

<div class="product-card">
  <a href={productUrl} class="card-link">
    <div class="card-image">
      <div class="card-image-placeholder">
        <span>{product.name.charAt(0)}</span>
      </div>
    </div>
    <div class="card-info">
      <h3 class="card-title">{product.name}</h3>
      <div class="card-price-row">
        <p class="card-price">&euro;{priceFormatted}</p>
        <span class={product.inStock ? 'card-stock in' : 'card-stock out'}>
          {product.inStock ? 'In Stock' : 'Out of Stock'}
        </span>
      </div>
    </div>
  </a>
  {product.inStock ? (
    <button
      class="card-btn add-to-cart-btn"
      data-slug={product.slug}
      data-price-id={product.stripePriceId}
    >
      Add to Cart
    </button>
  ) : (
    <a href={productUrl} class="card-btn notify-btn">
      Notify Me
    </a>
  )}
</div>

<script>
  import { addToCart } from '../stores/cart';

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.add-to-cart-btn');
    if (!btn) return;

    const slug = btn.getAttribute('data-slug');
    const priceId = btn.getAttribute('data-price-id');
    if (!slug || !priceId) return;

    addToCart(slug, priceId);
    btn.textContent = 'Added!';
    btn.classList.add('added');
    setTimeout(() => {
      btn.textContent = 'Add to Cart';
      btn.classList.remove('added');
    }, 1500);
  });
</script>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }

  .product-card:hover {
    border-color: var(--text-muted);
    transform: translateY(-2px);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    color: var(--text);
    text-decoration: none;
  }

  .card-link:hover {
    color: var(--text);
  }

  .card-image {
    aspect-ratio: 1;
    background: var(--bg-surface);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
  }

  .card-image-placeholder span {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--text-muted);
    opacity: 0.3;
  }

  .card-info {
    padding: 1rem;
  }

  .card-title {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .card-price-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-price {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--accent);
    letter-spacing: 0.02em;
  }

  .card-stock {
    font-size: 0.75rem;
    font-weight: 500;
  }

  .card-stock.in {
    color: #2ecc71;
  }

  .card-stock.out {
    color: var(--text-muted);
  }

  .card-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1rem;
    margin: 0 1rem 1rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    text-decoration: none;
  }

  .add-to-cart-btn {
    background: var(--accent);
    color: #fff;
  }

  .add-to-cart-btn:hover {
    background: var(--accent-hover);
  }

  .add-to-cart-btn.added {
    background: #2ecc71;
  }

  .notify-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .notify-btn:hover {
    border-color: var(--text-muted);
    color: var(--text);
  }
</style>
