---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found">
  <div class="not-found">
    <h1>404</h1>
    <p>This page doesn't exist.</p>
    <a href="/shop/" class="btn" style="margin-top: 2rem;">Back to Shop</a>
  </div>
</Layout>

<style>
  .not-found {
    text-align: center;
    padding: 6rem 0;
  }

  .not-found h1 {
    font-family: var(--font-display);
    font-size: 8rem;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .not-found p {
    color: var(--text-muted);
    font-size: 1.2rem;
  }
</style>
