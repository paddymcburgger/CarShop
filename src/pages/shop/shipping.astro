---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Shipping & Returns — Detailing Riga" description="Shipping information, delivery times, and return policy for Detailing Riga shop.">
  <nav class="breadcrumb">
    <a href="/shop/">Shop</a>
    <span>/</span>
    <span>Shipping & Returns</span>
  </nav>

  <h1 class="section-title">SHIPPING & RETURNS</h1>

  <div class="info-content">
    <section class="info-section">
      <h2>Delivery</h2>
      <p>We ship from Riga, Latvia. Standard delivery times:</p>
      <div class="info-table">
        <div class="info-row">
          <span class="info-label">Latvia</span>
          <span>1–3 business days</span>
        </div>
        <div class="info-row">
          <span class="info-label">Estonia, Lithuania</span>
          <span>2–5 business days</span>
        </div>
        <div class="info-row">
          <span class="info-label">EU</span>
          <span>5–10 business days</span>
        </div>
      </div>
    </section>

    <section class="info-section">
      <h2>Shipping Costs</h2>
      <p>Shipping costs are calculated at checkout based on your location and order weight.</p>
      <!-- TODO: Add free shipping threshold if applicable -->
    </section>

    <section class="info-section">
      <h2>Returns</h2>
      <p>We accept returns within 14 days of delivery for unused, unopened products in original packaging. Contact us to initiate a return.</p>
      <!-- TODO: Add contact email -->
    </section>

    <section class="info-section">
      <h2>Questions?</h2>
      <p>Reach out to us if you have any questions about your order.</p>
      <!-- TODO: Add contact info / link -->
    </section>
  </div>
</Layout>

<style>
  .info-content {
    max-width: 700px;
  }

  .info-section {
    margin-bottom: 3rem;
  }

  .info-section h2 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }

  .info-section p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .info-table {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .info-row {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 0.9rem;
  }

  .info-label {
    font-weight: 500;
  }
</style>
