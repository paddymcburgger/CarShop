---
import Layout from '../../../layouts/Layout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import AddToCartButton from '../../../components/AddToCartButton.tsx';
import { products, getProductBySlug, getRelatedProducts, categories, subcategories } from '../../../data/products';
import type { Subcategory } from '../../../data/products';

export function getStaticPaths() {
  return products.map((p) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const product = getProductBySlug(slug!)!;
const related = getRelatedProducts(product);
const priceFormatted = (product.price / 100).toFixed(2);
const categoryName = categories[product.category].name;
const subName = product.subcategory ? subcategories[product.subcategory as Subcategory] : null;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  offers: {
    '@type': 'Offer',
    price: priceFormatted,
    priceCurrency: 'EUR',
    availability: product.inStock
      ? 'https://schema.org/InStock'
      : 'https://schema.org/OutOfStock',
  },
});
---

<Layout title={`${product.name} — Detailing Riga`} description={product.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <nav class="breadcrumb">
    <a href="/shop/">Shop</a>
    <span>/</span>
    <a href={`/shop/${product.category === 'air-fresheners' ? 'air-fresheners' : 'jdm'}/`}>{categoryName}</a>
    {subName && (
      <>
        <span>/</span>
        <a href={`/shop/air-fresheners/${product.subcategory}/`}>{subName}</a>
      </>
    )}
    <span>/</span>
    <span>{product.name}</span>
  </nav>

  <div class="product-detail">
    <div class="product-image">
      <div class="image-placeholder">
        <span>{product.name.charAt(0)}</span>
      </div>
    </div>

    <div class="product-info">
      <h1 class="product-name">{product.name}</h1>
      <p class="product-price">&euro;{priceFormatted}</p>
      <p class="product-description">{product.description}</p>

      <div class="product-meta">
        <span class="meta-label">Category:</span>
        <a href={`/shop/${product.category === 'air-fresheners' ? 'air-fresheners' : 'jdm'}/`}>{categoryName}</a>
        {subName && (
          <>
            <span class="meta-label" style="margin-left: 1rem;">Type:</span>
            <a href={`/shop/air-fresheners/${product.subcategory}/`}>{subName}</a>
          </>
        )}
      </div>

      <div class="product-actions">
        <AddToCartButton
          slug={product.slug}
          stripePriceId={product.stripePriceId}
          inStock={product.inStock}
          client:load
        />
      </div>
    </div>
  </div>

  {related.length > 0 && (
    <section class="related">
      <h2 class="section-title">RELATED PRODUCTS</h2>
      <div class="product-grid">
        {related.map((p) => (
          <ProductCard product={p} />
        ))}
      </div>
    </section>
  )}
</Layout>

<style>
  .product-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .product-image {
    aspect-ratio: 1;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
  }

  .image-placeholder span {
    font-family: var(--font-display);
    font-size: 6rem;
    color: var(--text-muted);
    opacity: 0.15;
  }

  .product-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .product-name {
    font-family: var(--font-display);
    font-size: 2.5rem;
    letter-spacing: 0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .product-price {
    font-family: var(--font-display);
    font-size: 2.2rem;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .product-description {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .product-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .meta-label {
    font-weight: 500;
    color: var(--text-muted);
  }

  .product-meta a {
    color: var(--text);
    font-weight: 500;
  }

  .product-actions {
    max-width: 320px;
  }

  .related {
    margin-top: 2rem;
  }

  @media (max-width: 768px) {
    .product-detail {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .product-name {
      font-size: 1.8rem;
    }

    .product-price {
      font-size: 1.6rem;
    }

    .product-actions {
      max-width: 100%;
    }
  }
</style>
